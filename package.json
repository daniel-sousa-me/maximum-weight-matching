{
  "name": "maximum-weight-matching",
  "version": "1.0.1",
  "description": "Maximum weight matching in general graphs using Edmonds' blossom algorithm",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "matching",
    "maximum-weight-matching",
    "blossom",
    "graph",
    "edmonds"
  ],
  "author": "Daniel Sousa <npmjs.com@daniel.sousa.me>",
  "repository": {
    "type": "git",
    "url": "https://github.com/daniel-sousa-me/maximum-weight-matching.git"
  },
  "homepage": "https://github.com/daniel-sousa-me/maximum-weight-matching#readme",
  "bugs": {
    "url": "https://github.com/daniel-sousa-me/maximum-weight-matching/issues"
  },
  "license": "GPL-3.0",
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^3.0.0"
  }
}
